<script>
    // ─── MATRIX BACKGROUND ───
    const canvas = document.getElementById('matrix');
    const ctx = canvas.getContext('2d');
    function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);
    const mDrops = Array(Math.floor(canvas.width / 20)).fill(1);
    function drawMatrix() {
        ctx.fillStyle = "rgba(6,7,10,0.15)";
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = "#004455"; ctx.font = "13px monospace";
        mDrops.forEach((y, i) => {
            ctx.fillText(Math.random() > 0.5 ? "0" : "1", i * 20, y * 20);
            if (y * 20 > canvas.height && Math.random() > 0.98) mDrops[i] = 0;
            mDrops[i]++;
        });
    }
    setInterval(drawMatrix, 50);

    // ─── TERMINAL LINES ───
    const terminalLines = document.getElementById('matrix-code-lines');
    const chars = "010011011000110101110110";
    const eggs = ["M-chaT", "MARUF", "CHAOS", "29.05.26"];
    function updateTerminal() {
        let line = Math.random() > 0.9
            ? eggs[Math.floor(Math.random() * eggs.length)].padEnd(18, " ")
            : Array.from({length: 18}, () => chars[Math.floor(Math.random() * chars.length)]).join('');
        const div = document.createElement('div');
        div.innerText = line;
        terminalLines.appendChild(div);
        if (terminalLines.childNodes.length > 22) terminalLines.removeChild(terminalLines.firstChild);
    }
    setInterval(updateTerminal, 150);

    // ─── CHAOS INPUT ───
    const inp = document.getElementById('chaos-input');
    const out = document.getElementById('chaos-output');
    const symbols = "🔣∆§ψΩ*/4M≈Ω§ΣλμΔ∇⚙⚡$q3*!%&8#@^~";
    inp.addEventListener('input', (e) => {
        const v = e.target.value;
        if (!v) { out.innerText = "_"; return; }
        out.innerText = Array.from(v).map(() => symbols[Math.floor(Math.random() * symbols.length)]).join('');
    });

    // ─── SCROLL FADE TERMINAL ───
    window.onscroll = () => {
        const term = document.getElementById('hacker-window');
        if (term) term.style.opacity = window.scrollY > 500 ? "0" : "1";
    };

    // ─── THEME TOGGLE ───
    const html = document.documentElement;
    const btn = document.getElementById('themeToggle');
    const stored = localStorage.getItem('mchat-theme');
    if (stored) html.setAttribute('data-theme', stored);

    btn.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('mchat-theme', next);
    });
</script>
